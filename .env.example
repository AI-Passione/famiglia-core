# --- GitHub Configuration ---
# Required for semantic-release to create releases and push tags
GH_TOKEN=your_github_token_here

# --- Docker Configuration ---
# The name of the Docker image to build and push
DOCKER_IMAGE_NAME=ghcr.io/your_org/famiglia-core
DOCKER_REGISTRY=ghcr.io

# --- Application Configuration ---
# Custom environment variables for the Famiglia Core engine
LOG_LEVEL=INFO
ENVIRONMENT=development
