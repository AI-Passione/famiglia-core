# --- CI/CD Configuration ---
# Required for CI/CD workflows and semantic-release
GH_TOKEN=

# --- Docker Configuration ---
# The name of the Docker image to build and push
DOCKER_IMAGE_NAME=ghcr.io/ai-passione/famiglia-core
DOCKER_REGISTRY=ghcr.io

# --- Application Configuration ---
# Runtime Environment (production or development)
# In production, messages from DEV_CHANNEL_ID are ignored. 
# In development, ONLY messages from DEV_CHANNEL_ID are handled.
APP_ENV=development
ENVIRONMENT=development
LOG_LEVEL=INFO

# Command Center Configuration
FRONTEND_BASE_URL=https://localhost:5173
BACKEND_BASE_URL=https://localhost:8000
# Optional extra comma-separated browser origins for CORS, such as
# a GitHub Pages preview URL or an additional custom domain.
# Example production value:
# CORS_ALLOW_ORIGINS=https://aipassione.com,https://ai-passione.github.io
CORS_ALLOW_ORIGINS=

# Slack Configuration
# Optional global bot token (used when individual agent tokens aren't set).
# If you supply this value and also per-agent tokens, the explicit
# per-agent values will take precedence.
#
# IMPORTANT: every agent SHOULD have a distinct token. The service will
# refuse to start if two agents share the same bot token.
# SLACK_BOT_TOKEN=xoxb-your-global-bot-token

# Observability (Grafana + Loki)
# Set a strong password before starting docker-compose.prod.yml
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
# Keep private by default. Set to 0.0.0.0 for web access.
GRAFANA_BIND_ADDRESS=127.0.0.1
# Optional when exposing Grafana on a domain
GRAFANA_DOMAIN=localhost
GRAFANA_ROOT_URL=https://localhost:3000

# LLM Fallback – 3-tier order
# Tier 1: Cloud AI – used when the corresponding API key is set (GEMINI_API_KEY, PERPLEXITY_API_KEY, ANTHROPIC_API_KEY)
# Tier 2: Local Ollama – preferred fallback for fast/simple chats (spun up automatically if the ollama binary is present)
OLLAMA_HOST=localhost
# Tier 3: Remote self-hosted Ollama – fallback for heavier/complex tasks when local is unavailable
OLLAMA_REMOTE_HOST=https://[IP_ADDRESS]
OLLAMA_FALLBACK_MODEL=gemma3:4b
# Optional API key for some Ollama providers/access layers
OLLAMA_API_KEY=

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=passione_admin
DB_PASSWORD=passione_password
DB_NAME=passione_db
# Set to false to disable context/memory persistence in PostgreSQL.
AGENT_CONTEXT_ENABLED=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Scheduled Tasks Queue
SCHEDULED_TASKS_ENABLED=true
SCHEDULED_TASK_POLL_SECONDS=5
SCHEDULED_TASK_SLOT_MINUTES=1
SCHEDULED_TASK_BASE_PICKUP_MINUTES=1
SCHEDULED_TASK_DEFAULT_DURATION_MINUTES=90

# Scheduled Tasks Control Panel
SCHEDULED_TASKS_CONTROL_PANEL_ENABLED=true
SCHEDULED_TASKS_CONTROL_PANEL_HOST=127.0.0.1
SCHEDULED_TASKS_CONTROL_PANEL_PORT=8787

# GitHub Integration
# For agents like Riccardo and Rossini that interact with GitHub Repositories.
# Note: Provide the full contents of the downloaded .pem file as a literal multi-line string.
GITHUB_APP_ID_RICCARDO=
GITHUB_APP_INSTALLATION_ID_RICCARDO=
GITHUB_APP_PRIVATE_KEY_RICCARDO=

GITHUB_APP_ID_ROSSINI=
GITHUB_APP_INSTALLATION_ID_ROSSINI=
GITHUB_APP_PRIVATE_KEY_ROSSINI=

# GitHub OAuth App (for human user connection via the Command Center dashboard)
# Create one at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Callback URL for local dev: https://localhost:8000/auth/github/callback
# Production example: https://api.aipassione.com/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://localhost:8000/auth/github/callback

# CRITICAL: Encryption key for OAuth tokens stored in the database (Fernet symmetric key).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: If you lose this key, you lose access to all stored encrypted tokens.
FERNET_SECRET=

# Langfuse Observability (Local)
LANGFUSE_PUBLIC_KEY=pk-lf-1234567890
LANGFUSE_SECRET_KEY=sk-lf-1234567890
LANGFUSE_HOST=https://localhost:3001
LANGFUSE_SALT=super-secret-salt-for-local-use-only
LANGFUSE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# Production Domain (for Caddy SSL)
PRODUCTION_DOMAIN=demo.aipassione.com
ACME_EMAIL=admin@ai-passione.com
REDIS_PASSWORD=
